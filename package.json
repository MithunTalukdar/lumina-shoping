
{
  "name": "lumina-commerce",
  "version": "1.0.0",
  "description": "Lumina Commerce monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "server": "npm run dev:backend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "typecheck": "npm --prefix frontend run typecheck",
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm run install:frontend && npm run install:backend"
  }
}
