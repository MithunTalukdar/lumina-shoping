# Environment files are separated:
# - frontend/.env.example
# - backend/.env.example
#
# For Vercel, add the backend variables in the Vercel project settings:
# - MONGODB_URI
# - MONGODB_DB
# - JWT_SECRET
# - JWT_EXPIRES_IN
# - CLIENT_URL
# - GOOGLE_CLIENT_ID
# - GOOGLE_CLIENT_SECRET
# - GOOGLE_CALLBACK_URL
# - GEMINI_API_KEY
# - GEMINI_MODEL
